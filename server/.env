# 服务器端口
PORT=3000

# 日志级别 (error/warn/info/debug)
LOG_LEVEL=info

# MySQL数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=kaoyan_db

# JWT密钥（以下为示例值，生产环境必须替换为随机生成的强密钥）
JWT_SECRET=your_jwt_secret_here_replace_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_replace_in_production

# Redis缓存配置（若不启用则使用内存缓存）
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=kaoyan:

# 微信小程序配置
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# 微信订阅消息模板ID
# 需要在微信小程序后台配置模板后填入
# 通知提醒模板（用于系统通知推送）
WECHAT_NOTIFICATION_TEMPLATE=

# 消息提醒模板（用于私聊消息推送）
WECHAT_MESSAGE_TEMPLATE=

# AI助手配置（OpenAI兼容API）
# 支持 OpenAI / DeepSeek / 通义千问 等兼容接口
# 不配置则使用内置的默认智能回复
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# CORS允许的来源（多个用逗号分隔，不配置则允许所有）
# ALLOWED_ORIGINS=https://your-domain.com,https://mp.weixin.qq.com