# 服务器端口
PORT=3000

# MySQL数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=kaoyan_db

# JWT密钥
JWT_SECRET=kaoyan-secret-key-2024

# 微信小程序配置
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# 微信订阅消息模板ID
# 需要在微信小程序后台配置模板后填入
# 通知提醒模板（用于系统通知推送）
WECHAT_NOTIFICATION_TEMPLATE=

# 消息提醒模板（用于私聊消息推送）
WECHAT_MESSAGE_TEMPLATE=
